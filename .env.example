# ─── REQUIRED: App will not function without these ───────────────────────────

# Upstash Redis — https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Stripe — https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret — Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the AI Visibility Scanner product — Dashboard → Products
STRIPE_PRICE_ID=price_...

# Resend email — https://resend.com → API Keys
RESEND_API_KEY=re_...

# Your deployed domain (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://queldrex.com

# Admin panel password
ADMIN_SECRET=your-strong-password-here

# ─── REQUIRED: AI tools return 503 without these ─────────────────────────────

# Groq — https://console.groq.com → API Keys (free tier, 14k req/day)
GROQ_API_KEY=gsk_...

# ─── OPTIONAL: AI Visibility Scanner additional signals ──────────────────────

# Anthropic — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com → API Keys
GEMINI_API_KEY=AIza...

# ─── OPTIONAL: DFY (Done-For-You) flow ───────────────────────────────────────

# Encryption key for stored credentials (32 random bytes, base64)
CREDENTIALS_ENCRYPTION_KEY=your-base64-32-byte-key

# Cal.com booking page URL (shown on DFY confirmation)
NEXT_PUBLIC_CAL_URL=https://cal.com/your-username/dfy-onboarding

# Cal.com webhook secret — Cal.com → Settings → Webhooks
CAL_WEBHOOK_SECRET=your-cal-webhook-secret

# ─── OPTIONAL: Multi-product Stripe webhooks ─────────────────────────────────

# If using separate Stripe webhook endpoints per product:
STRIPE_AGENCY_WEBHOOK_SECRET=whsec_...
STRIPE_MONITOR_WEBHOOK_SECRET=whsec_...

# ─── OPTIONAL: Cron job protection ───────────────────────────────────────────

# Passed as Authorization header to /api/cron/* routes
CRON_SECRET=your-cron-secret

# ─── OPTIONAL: Admin SMS alerts ──────────────────────────────────────────────

ADMIN_EMAIL=hello@queldrex.com
ADMIN_PHONE=+13035550000

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15005550000
